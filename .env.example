# ── Local model (LM Studio) ───────────────────────────────────────────────────
# LM Studio default endpoint — no need to change unless you moved it
LOCAL_BASE_URL=http://localhost:1234/v1
LOCAL_API_KEY=lm-studio
# Set this to whatever model you have loaded in LM Studio
LOCAL_MODEL=qwen2.5-32b-instruct

# ── Cloud provider ────────────────────────────────────────────────────────────
# Choose: "anthropic" or "gemini"
CLOUD_PROVIDER=anthropic

# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google / Gemini (only needed if CLOUD_PROVIDER=gemini)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# ── Routing thresholds ────────────────────────────────────────────────────────
# Score 0–100. Prompts scoring below this go to your local model.
# Lower = more goes local. Raise if local model quality isn't good enough.
COMPLEXITY_THRESHOLD=50

# Prompts estimated over this many tokens always go to cloud regardless of score
MAX_LOCAL_TOKENS=3000

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Set to "false" to silence per-request routing logs
LOG_DECISIONS=true
